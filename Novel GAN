{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":13453826,"datasetId":8539928,"databundleVersionId":14170822},{"sourceType":"kernelVersion","sourceId":288073367}],"dockerImageVersionId":31236,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# This Python 3 environment comes with many helpful analytics libraries installed\n# It is defined by the kaggle/python Docker image: https://github.com/kaggle/docker-python\n# For example, here's several helpful packages to load\n\nimport numpy as np # linear algebra\nimport pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)\n\n# Input data files are available in the read-only \"../input/\" directory\n# For example, running this (by clicking run or pressing Shift+Enter) will list all files under the input directory\n\nimport os\nfor dirname, _, filenames in os.walk('/kaggle/input'):\n    for filename in filenames:\n        # print(os.path.join(dirname, filename))\n        pass\n\n# You can write up to 20GB to the current directory (/kaggle/working/) that gets preserved as output when you create a version using \"Save & Run All\" \n# You can also write temporary files to /kaggle/temp/, but they won't be saved outside of the current session","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2025-12-23T17:30:14.664339Z","iopub.status.idle":"2025-12-23T17:30:14.664615Z","shell.execute_reply.started":"2025-12-23T17:30:14.664495Z","shell.execute_reply":"2025-12-23T17:30:14.664511Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os, random, shutil\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom tqdm import tqdm\nfrom scipy.ndimage import gaussian_filter\n\nimport tensorflow as tf\nfrom tensorflow.keras.preprocessing.image import load_img, img_to_array\nfrom tensorflow.keras.optimizers import Adam\n# ================= PATHS =================\nDATA_DIR = \"/kaggle/input/gallbladder-split/kaggle/working/gallbladder_split\"\n\nTRAIN_DIR = os.path.join(DATA_DIR, \"train\")\nVAL_DIR   = os.path.join(DATA_DIR, \"val\")\nTEST_DIR  = os.path.join(DATA_DIR, \"test\")\n\nOUTPUT_DIR = \"/kaggle/working/gan_outputs\"\nMODEL_DIR  = os.path.join(OUTPUT_DIR, \"models\")\nFIG_DIR    = os.path.join(OUTPUT_DIR, \"figures\")\nSAMPLE_DIR = os.path.join(FIG_DIR, \"epoch_samples\")\n\nfor d in [OUTPUT_DIR, MODEL_DIR, FIG_DIR, SAMPLE_DIR]:\n    os.makedirs(d, exist_ok=True)\n    \nIMG_SIZE = 224          # 🔴 SAME AS ViT\nBATCH_SIZE = 32\nGAN_EPOCHS = 40\n\nREAL_LABEL = 1.0\nFAKE_LABEL = 0.0\n\ndef collect_paths(base_dir):\n    paths = []\n    for cls in os.listdir(base_dir):\n        cls_dir = os.path.join(base_dir, cls)\n        if not os.path.isdir(cls_dir): continue\n        for f in os.listdir(cls_dir):\n            if f.lower().endswith((\".png\",\".jpg\",\".jpeg\")):\n                paths.append(os.path.join(cls_dir, f))\n    return paths\n\ntrain_p = collect_paths(TRAIN_DIR)\nval_p   = collect_paths(VAL_DIR)\ntest_p  = collect_paths(TEST_DIR)\n\nprint(f\"Train: {len(train_p)}, Val: {len(val_p)}, Test: {len(test_p)}\")\n\ndef preprocess(path, noisy=True, level=\"medium\"):\n    img = img_to_array(\n        load_img(path, target_size=(IMG_SIZE, IMG_SIZE))\n    ).astype(\"float32\") / 255.0\n\n    clean = img.copy()\n    if not noisy:\n        return clean\n\n    noisy_img = clean.copy()\n\n    if level == \"low\":\n        speckle, gauss, blur_p, blur_s, sp_rng = (0.03,0.06),(0.01,0.02),0.2,(0.3,0.6),(0.002,0.006)\n    elif level == \"high\":\n        speckle, gauss, blur_p, blur_s, sp_rng = (0.12,0.25),(0.05,0.10),0.6,(1.0,2.0),(0.02,0.05)\n    else:  # medium\n        speckle, gauss, blur_p, blur_s, sp_rng = (0.06,0.12),(0.02,0.05),0.4,(0.6,1.2),(0.01,0.03)\n\n    noisy_img += noisy_img * np.random.normal(0, np.random.uniform(*speckle), noisy_img.shape)\n    noisy_img += np.random.normal(0, np.random.uniform(*gauss), noisy_img.shape)\n\n    if np.random.rand() < blur_p:\n        sigma = np.random.uniform(*blur_s)\n        noisy_img = gaussian_filter(noisy_img, sigma=(sigma, sigma, 0))\n\n    sp = np.random.uniform(*sp_rng)\n    mask = np.random.rand(*noisy_img.shape[:2])\n    noisy_img[mask < sp/2] = 0.0\n    noisy_img[mask > 1-sp/2] = 1.0\n\n    return np.clip(noisy_img,0,1)\n\ndef batch_generator(paths, batch_size, noise_level=\"medium\"):\n    while True:\n        idx = np.random.choice(len(paths), batch_size)\n        clean = np.array([preprocess(paths[i], False) for i in idx])\n        noisy = np.array([preprocess(paths[i], True, noise_level) for i in idx])\n        yield noisy, clean\n\n# ================= NORMALIZATION LAYER =================\n# ================= REQUIRED LAYERS & NORMALIZATION =================\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.layers import (\n    Input, Conv2D, Conv2DTranspose, Dense,\n    BatchNormalization, Activation, Add, Multiply,\n    Concatenate, GlobalAveragePooling2D,\n    LeakyReLU, Dropout, Reshape\n)\n\n# Prefer InstanceNorm if available (better for GANs)\ntry:\n    from tensorflow_addons.layers import InstanceNormalization\n    NormLayer = InstanceNormalization\n    print(\"✅ Using InstanceNormalization\")\nexcept:\n    NormLayer = BatchNormalization\n    print(\"⚠️ InstanceNormalization not found, using BatchNormalization\")\n\n\n\ndef res_se_block(x_in, filters, kernel_size=3, reduction=16, norm=NormLayer):\n    shortcut = x_in\n\n    x = Conv2D(filters, kernel_size, padding='same', use_bias=False)(x_in)\n    x = norm()(x)\n    x = Activation('relu')(x)\n\n    x = Conv2D(filters, kernel_size, padding='same', use_bias=False)(x)\n    x = norm()(x)\n\n    # SE block\n    se = GlobalAveragePooling2D()(x)\n    se = Dense(max(filters // reduction, 4), activation='relu')(se)\n    se = Dense(filters, activation='sigmoid')(se)\n    se = Reshape((1, 1, filters))(se)\n    x = Multiply()([x, se])\n\n    in_channels = int(shortcut.shape[-1])\n    if in_channels != filters:\n        shortcut = Conv2D(filters, 1, padding='same', use_bias=False)(shortcut)\n        shortcut = norm()(shortcut)\n\n    x = Add()([x, shortcut])\n    x = Activation('relu')(x)\n    return x\n\ndef attention_gate(skip, gating, inter_channels):\n    theta_x = Conv2D(inter_channels, 1, strides=1, padding='same')(skip)\n    phi_g = Conv2D(inter_channels, 1, strides=1, padding='same')(gating)\n    f = Activation('relu')(Add()([theta_x, phi_g]))\n    psi = Conv2D(1, 1, padding='same', activation='sigmoid')(f)\n    return Multiply()([skip, psi])\n\ndef down_block(x, filters, kernel_size=4, strides=2, norm=NormLayer):\n    x = Conv2D(filters, kernel_size, strides=strides, padding='same', use_bias=False)(x)\n    x = norm()(x)\n    x = LeakyReLU(0.2)(x)\n    x = res_se_block(x, filters, norm=norm)\n    return x\n\ndef up_block(x, skip, filters, kernel_size=4, strides=2, norm=NormLayer, use_dropout=False, attention=False):\n    x = Conv2DTranspose(filters, kernel_size, strides=strides, padding='same', use_bias=False)(x)\n    x = norm()(x)\n    x = Activation('relu')(x)\n    x = res_se_block(x, filters, norm=norm)\n\n    if use_dropout:\n        x = Dropout(0.3)(x)\n\n    if attention:\n        refined_skip = attention_gate(skip, x, inter_channels=max(filters//2, 16))\n        x = Concatenate()([x, refined_skip])\n    else:\n        x = Concatenate()([x, skip])\n\n    return x\n\ndef build_medical_res_se_unet(img_shape=(224,224,3), base_filters=64, use_attention=True, use_dropout_in_decoder=True):\n    inputs = Input(img_shape)\n\n    # Encoder\n    e1 = down_block(inputs, base_filters)\n    e2 = down_block(e1, base_filters*2)\n    e3 = down_block(e2, base_filters*4)\n    e4 = down_block(e3, base_filters*8)\n\n    # Bottleneck\n    b = Conv2D(base_filters*8, 4, strides=2, padding='same', use_bias=False)(e4)\n    b = NormLayer()(b)\n    b = Activation('relu')(b)\n    b = res_se_block(b, base_filters*8, norm=NormLayer)\n\n    # Decoder\n    d1 = up_block(b, e4, base_filters*8, use_dropout=use_dropout_in_decoder, attention=use_attention)\n    d2 = up_block(d1, e3, base_filters*4, use_dropout=use_dropout_in_decoder, attention=use_attention)\n    d3 = up_block(d2, e2, base_filters*2, use_dropout=use_dropout_in_decoder, attention=use_attention)\n    d4 = up_block(d3, e1, base_filters, use_dropout=use_dropout_in_decoder, attention=use_attention)\n\n    outputs = Conv2DTranspose(3, 4, strides=2, padding='same', activation='sigmoid')(d4)\n\n    model = Model(inputs, outputs, name=\"Med_ResSE_UNet_Generator\")\n    return model\n\n# Example:\nG = build_medical_res_se_unet()\nG.summary()\n\nfrom tensorflow.keras.layers import Conv2D, LeakyReLU, Add, Activation, Dropout\nfrom tensorflow.keras.layers import Layer, Conv2D, Add, Reshape, Softmax\nimport tensorflow as tf\n\n# Residual block\ndef residual_block(x, filters, stride=1):\n    shortcut = x\n    x = Conv2D(filters, 4, strides=stride, padding='same')(x)\n    x = LeakyReLU(0.2)(x)\n    x = Conv2D(filters, 4, strides=1, padding='same')(x)\n    if shortcut.shape[-1] != filters:\n        shortcut = Conv2D(filters,1,strides=stride,padding='same')(shortcut)\n    x = Add()([x,shortcut])\n    x = LeakyReLU(0.2)(x)\n    return x\n\n# Self-attention\nclass SelfAttention(Layer):\n    def __init__(self, filters):\n        super(SelfAttention, self).__init__()\n        self.filters = filters\n        self.f_conv = Conv2D(filters//8, 1, padding='same')\n        self.g_conv = Conv2D(filters//8, 1, padding='same')\n        self.h_conv = Conv2D(filters, 1, padding='same')\n        self.v_conv = Conv2D(filters, 1, padding='same')\n        self.softmax = Softmax(axis=-1)\n\n    def call(self, x):\n        batch_size, h, w, c = tf.shape(x)[0], tf.shape(x)[1], tf.shape(x)[2], tf.shape(x)[3]\n\n        f = self.f_conv(x)  # [B, H, W, C//8]\n        g = self.g_conv(x)  # [B, H, W, C//8]\n        h_ = self.h_conv(x) # [B, H, W, C]\n\n        # Flatten spatial dimensions\n        f_flat = tf.reshape(f, [batch_size, -1, self.filters//8])  # [B, N, C//8]\n        g_flat = tf.reshape(g, [batch_size, -1, self.filters//8])  # [B, N, C//8]\n        h_flat = tf.reshape(h_, [batch_size, -1, self.filters])    # [B, N, C]\n\n        s = tf.matmul(g_flat, f_flat, transpose_b=True)             # [B, N, N]\n        beta = self.softmax(s)                                      # attention map\n\n        o = tf.matmul(beta, h_flat)                                 # [B, N, C]\n        o = tf.reshape(o, [batch_size, h, w, c])\n        o = self.v_conv(o)\n        return Add()([x, o])\n\n# Build discriminator\ndef build_discriminator(img_shape=(224,224,3)):\n    inp = Input(img_shape)\n    x = Conv2D(64,4,strides=2,padding='same')(inp)\n    x = LeakyReLU(0.2)(x)\n    x = residual_block(x,128,stride=2)\n    x = Dropout(0.3)(x)\n    x = residual_block(x,256,stride=2)\n    x = SelfAttention(256)(x)\n    x = Dropout(0.3)(x)\n    x = residual_block(x,512,stride=2)\n    x = Dropout(0.3)(x)\n    x = Conv2D(1,4,padding='same')(x)\n    outputs = Activation('sigmoid')(x)\n    return Model(inp, outputs, name=\"Attention_Discriminator\")\n\n\n# Example:\nD = build_discriminator()\nD.summary()\n\n# ================= COMPILE GAN =================\ndiscriminator = D\ngenerator = G\n\n# Create optimizers with gradient clipping\nd_optimizer = Adam(1e-4, 0.5, clipnorm=1.0)  # Lower LR + clipping for D\ng_optimizer = Adam(2e-4, 0.5, clipnorm=1.0)  # Normal for G\n\n# Compile discriminator with MSE (LSGAN) + gradient clipping\ndiscriminator.compile(\n    loss=\"mse\",  # LSGAN instead of BCE\n    optimizer=d_optimizer,\n    metrics=[\"accuracy\"]\n)\n\ndiscriminator.trainable = False\n\n# Compile GAN\nz = Input(shape=(IMG_SIZE, IMG_SIZE, 3))\ngen_out = generator(z)\nvalidity = discriminator(gen_out)\n\ngan = Model(z, [validity, gen_out])\ngan.compile(\n    loss=[\"mse\", \"mae\"],  # LSGAN + MAE\n    loss_weights=[1, 100],\n    optimizer=g_optimizer\n)\n\ntrain_gen = batch_generator(train_p, BATCH_SIZE, \"medium\")\nval_gen   = batch_generator(val_p, BATCH_SIZE, \"medium\")\n\nsteps_per_epoch = len(train_p) // BATCH_SIZE\npatch_shape = discriminator.output_shape[1:]\n\n# Metrics\nfrom skimage.metrics import peak_signal_noise_ratio as psnr\nfrom skimage.metrics import structural_similarity as ssim\n\n# ================= FIXED TRAINING LOOP =================\nd_losses_all, g_losses_all = [], []\npsnr_all, ssim_all = [], []\n\nprint(\"\\n🚀 Training STABILIZED GAN with ResSE-UNet + Attention...\\n\")\n\nfor epoch in range(GAN_EPOCHS):\n    print(f\"\\n===== Epoch {epoch+1}/{GAN_EPOCHS} =====\")\n    d_losses, g_losses = [], []\n\n    # Adaptive D steps: more at start, reduce over time\n    n_d_steps = max(1, 3 - epoch//15)  \n    \n    progress_bar = tqdm(range(steps_per_epoch), desc=\"Training\")\n    for step in progress_bar:\n        noisy_imgs, clean_imgs = next(train_gen)\n        \n        # Generate fakes ONCE per batch (efficient)\n        fake_imgs = generator(noisy_imgs, training=False)\n        \n        real_y = np.ones((BATCH_SIZE, *patch_shape))\n        fake_y = np.zeros((BATCH_SIZE, *patch_shape))\n        \n        # === TRAIN DISCRIMINATOR ===\n        discriminator.trainable = True\n        for _ in range(n_d_steps):\n            d_loss = discriminator.train_on_batch(\n                np.concatenate([clean_imgs, fake_imgs]), \n                np.concatenate([real_y, fake_y])\n            )\n        discriminator.trainable = False\n        d_losses.append(d_loss[0])\n        \n        # === TRAIN GENERATOR ===\n        g_loss = gan.train_on_batch(noisy_imgs, [real_y, clean_imgs])\n        g_losses.append(g_loss[0])\n        \n        # Update progress bar\n        progress_bar.set_postfix({\n            'D': f\"{np.mean(d_losses[-10:]):.3f}\", \n            'G': f\"{np.mean(g_losses[-10:]):.3f}\"\n        })\n\n    # === VALIDATION ===\n    v = random.randint(0, len(val_p) - 1)\n    clean = preprocess(val_p[v], False)\n    noisy = preprocess(val_p[v], True, \"medium\")\n    den = generator.predict(noisy[None,...], verbose=0)[0]\n\n    # Clamp for safety\n    clean, noisy, den = np.clip([clean, noisy, den], 0, 1)\n    \n    p = psnr(clean, den, data_range=1.0)\n    s = ssim(clean, den, channel_axis=-1, data_range=1.0)\n\n    # Store metrics\n    d_losses_all.append(np.mean(d_losses))\n    g_losses_all.append(np.mean(g_losses))\n    psnr_all.append(p)\n    ssim_all.append(s)\n\n    # === VISUALIZATION ===\n    plt.figure(figsize=(12,4))\n    for i, (img, title) in enumerate(zip([noisy, den, clean], [\"Noisy\", \"Denoised\", \"Clean\"])):\n        plt.subplot(1, 3, i + 1)\n        plt.imshow(img)\n        plt.title(title)\n        plt.axis(\"off\")\n\n    plt.suptitle(f\"Epoch {epoch+1} | PSNR {p:.2f} | SSIM {s:.3f} | D_steps: {n_d_steps}\")\n    plt.show()\n    \n    # SAVE FIGURE\n    plt.savefig(os.path.join(SAMPLE_DIR, f\"epoch_{epoch+1:02d}.png\"), dpi=300, bbox_inches=\"tight\")\n    plt.close()\n\n    # === SAVE MODELS (.keras format!) ===\n    generator.save(os.path.join(MODEL_DIR, f\"generator_epoch_{epoch+1:02d}.keras\"))\n    discriminator.save(os.path.join(MODEL_DIR, f\"discriminator_epoch_{epoch+1:02d}.keras\"))\n    \n    # Save best model by PSNR\n    if len(psnr_all) == 1 or p > max(psnr_all[:-1]):\n        generator.save(os.path.join(MODEL_DIR, \"BEST_generator.keras\"))\n        print(f\"🎉 NEW BEST PSNR: {p:.2f}\")\n\n    print(f\"D: {np.mean(d_losses):.4f} | G: {np.mean(g_losses):.4f} | PSNR: {p:.2f} | SSIM: {s:.3f}\")\n\n# === FINAL PLOTS ===\nplt.figure(figsize=(15,5))\nplt.subplot(1,3,1); plt.plot(d_losses_all, 'b-', label=\"D\"); plt.plot(g_losses_all, 'r-', label=\"G\"); plt.legend(); plt.title(\"Losses\")\nplt.subplot(1,3,2); plt.plot(psnr_all); plt.title(\"PSNR\"); plt.ylabel(\"PSNR\")\nplt.subplot(1,3,3); plt.plot(ssim_all); plt.title(\"SSIM\"); plt.ylabel(\"SSIM\")\nplt.tight_layout()\nplt.savefig(os.path.join(FIG_DIR, \"training_curves.png\"), dpi=300)\nplt.show()\n\n\nnoise_levels = [\"low\", \"medium\", \"high\"]\nsamples = random.sample(val_p, 3)\n\nfig, axes = plt.subplots(len(noise_levels), 9, figsize=(27,12))\n\nfor r, lvl in enumerate(noise_levels):\n    for c, pth in enumerate(samples):\n        clean = preprocess(pth, False)\n        noisy = preprocess(pth, True, lvl)\n        den   = generator.predict(noisy[None], verbose=0)[0]\n\n        axes[r,3*c].imshow(noisy); axes[r,3*c].set_title(f\"Noisy ({lvl})\"); axes[r,3*c].axis(\"off\")\n        axes[r,3*c+1].imshow(den); axes[r,3*c+1].set_title(\"Denoised\"); axes[r,3*c+1].axis(\"off\")\n        axes[r,3*c+2].imshow(clean); axes[r,3*c+2].set_title(\"Clean\"); axes[r,3*c+2].axis(\"off\")\n\nplt.tight_layout()\nplt.savefig(os.path.join(FIG_DIR, \"final_noise_level_comparison.png\"), dpi=300)\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-23T17:52:10.842078Z","iopub.execute_input":"2025-12-23T17:52:10.842765Z","iopub.status.idle":"2025-12-23T17:53:03.612480Z","shell.execute_reply.started":"2025-12-23T17:52:10.842732Z","shell.execute_reply":"2025-12-23T17:53:03.611519Z"}},"outputs":[],"execution_count":null}]}